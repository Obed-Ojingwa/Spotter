# App
APP_NAME=SPOTTER
APP_ENV=development
SECRET_KEY=super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://spotter:spotter_pass@db:5432/spotter

# Redis
REDIS_URL=redis://redis:6379/0

# Meilisearch
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=spotter_meili_key

# Paystack (get from dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here

# Email (optional for dev - logs to console if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM=noreply@spotter.ng

# File storage (local for dev)
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/app/uploads

# Pricing (in Naira kobo for Paystack - multiply by 100)
SEEKER_MATCH_PRICE=50000
ORG_UNLOCK_PRICE=1500000
ORG_JOB_POST_PRICE=500000
AGENT_PRO_MONTHLY=300000
POINTS_TO_NAIRA=2000